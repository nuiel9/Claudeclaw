{
  "description": "Secret scanning patterns for Claudeclaw",
  "patterns": [
    {
      "name": "Discord Bot Token",
      "pattern": "[MN][A-Za-z\\d]{23,}\\.[\\w-]{6}\\.[\\w-]{27,}",
      "severity": "critical"
    },
    {
      "name": "Telegram Bot Token",
      "pattern": "\\d{8,10}:[A-Za-z0-9_-]{35}",
      "severity": "critical"
    },
    {
      "name": "Generic API Key",
      "pattern": "(?i)(api[_-]?key|apikey|secret[_-]?key)\\s*[:=]\\s*['\"][A-Za-z0-9+/=]{20,}['\"]",
      "severity": "high"
    },
    {
      "name": "AWS Access Key",
      "pattern": "AKIA[0-9A-Z]{16}",
      "severity": "critical"
    },
    {
      "name": "Private Key Header",
      "pattern": "-----BEGIN (RSA |EC |DSA )?PRIVATE KEY-----",
      "severity": "critical"
    },
    {
      "name": "Generic Password in Config",
      "pattern": "(?i)(password|passwd|pwd)\\s*[:=]\\s*['\"][^'\"]{8,}['\"]",
      "severity": "high"
    },
    {
      "name": "Bearer Token",
      "pattern": "(?i)bearer\\s+[A-Za-z0-9\\-._~+/]+=*",
      "severity": "high"
    },
    {
      "name": "Anthropic API Key",
      "pattern": "sk-ant-[A-Za-z0-9-]{40,}",
      "severity": "critical"
    },
    {
      "name": "OpenAI API Key",
      "pattern": "sk-[A-Za-z0-9]{40,}",
      "severity": "critical"
    }
  ],
  "allowPaths": [
    "*.test.ts",
    "*.spec.ts",
    ".secret-scan.json"
  ]
}
